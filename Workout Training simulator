})

Tabs.Pets:AddToggle("AutoHatch", {Title = "Auto Hatch", Default = false }):OnChanged(function(Value)
    _G.AutoHatch = Value
    task.spawn(function()
        while _G.AutoHatch do
            pcall(function() invokeFunc("purchaseEgg", SelectedEgg, 1, {}) end)
            task.wait(0.1) -- Balik sa dating delay
        end
    end)
end)

Tabs.Pets:AddToggle("AutoCraft", {Title = "Auto Craft Pets", Default = false }):OnChanged(function(Value)
    _G.AutoCraft = Value
    task.spawn(function()
        while _G.AutoCraft do
            pcall(function() invokeFunc("modifyPetState", {}, "craftPets") end)
            task.wait(0.1)
        end
