end)

-- [[ REWARDS TAB ]]

Tabs.Rewards:AddToggle("AutoClaim", {Title = "Auto Claim Rewards", Default = false }):OnChanged(function(Value)
    _G.AutoClaim = Value
    task.spawn(function()
        while _G.AutoClaim do
            for i = 1, 15 do 
                if not _G.AutoClaim then break end
                pcall(function() invokeFunc("claimReward", {i}) end)
                task.wait(0.1)
            end
            task.wait(30) -- Balik sa dating 30s delay
        end
    end)
end)

Tabs.Rewards:AddToggle("AutoSpin", {Title = "Auto Spin Wheel", Default = false }):OnChanged(function(Value)
    _G.AutoSpin = Value
    task.spawn(function()
        while _G.AutoSpin do
            pcall(function() invokeFunc("spinWheel", 1, 1) end)
            task.wait(60)
        end
    end)
end)

