local Fluent = loadstring(game:HttpGetAsync("https://github.com/ActualMasterOogway/Fluent-Renewed/releases/latest/download/Fluent.luau"))()
local SaveManager = loadstring(game:HttpGet("https://raw.githubusercontent.com/dawid-scripts/Fluent/master/Addons/SaveManager.lua"))()
local InterfaceManager = loadstring(game:HttpGet("https://raw.githubusercontent.com/dawid-scripts/Fluent/master/Addons/InterfaceManager.lua"))()

local Window = Fluent:CreateWindow({
    Title = "Zantetsu Hub",
    SubTitle = "Typhoon V2 [X3 Boost Edition]",
    TabWidth = 160,
    Size = UDim2.fromOffset(580, 460),
    Acrylic = true,
    Theme = "Dark",
    MinimizeKey = Enum.KeyCode.LeftControl
})

local Tabs = {
    Main = Window:AddTab({ Title = "Main", Icon = "home" }),
    Pets = Window:AddTab({ Title = "Pets", Icon = "dog" }),
    Rewards = Window:AddTab({ Title = "Rewards", Icon = "gift" }),
    Settings = Window:AddTab({ Title = "Settings", Icon = "settings" })
}

-- [[ CENTRALIZED FUNCTIONS ]]

local function invokeFunc(...)
    local func = game:GetService("ReplicatedStorage"):WaitForChild("TyphoonFramework"):WaitForChild("Utilities"):WaitForChild("Network"):FindFirstChild("Func")
    if func then return func:InvokeServer(...) end
end

local function fireV2(action)
    local event = game:GetService("ReplicatedStorage"):WaitForChild("TyphoonFramework"):WaitForChild("Utilities"):WaitForChild("Network"):FindFirstChild("UnreliableEvent")
    if event then event:FireServer("inputEventV2", action) end
end

-- [[ SET RESPAWN LOGIC ]]
local Player = game.Players.LocalPlayer
local RespawnPos = nil

Player.CharacterAdded:Connect(function(Character)
    if _G.SetRespawn and RespawnPos then
        local hrp = Character:WaitForChild("HumanoidRootPart", 10)
        if hrp then
            task.wait(0.7) 
            hrp.CFrame = RespawnPos
        end
    end
end)

-- [[ MAIN TAB ]]

Tabs.Main:AddToggle("SetRespawn", {Title = "Set Respawn Point", Default = false }):OnChanged(function(Value)
    _G.SetRespawn = Value
    if Value then
        if Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
            RespawnPos = Player.Character.HumanoidRootPart.CFrame
            Fluent:Notify({ Title = "Zantetsu Hub", Content = "Respawn Position Set!", Duration = 3 })
        end
    else
        RespawnPos = nil
    end
end)

Tabs.Main:AddToggle("AutoRebirth", {Title = "Auto Rebirth", Default = false }):OnChanged(function(Value)
    _G.AutoRebirth = Value
    task.spawn(function()
        while _G.AutoRebirth do
            pcall(function() invokeFunc("rebirthRequest") end)
            task.wait(0.1) 
        end
    end)
end)

Tabs.Main:AddToggle("AutoWeight", {Title = "Auto Weight", Default = false }):OnChanged(function(Value)
    _G.AutoWeight = Value
    task.spawn(function()
        while _G.AutoWeight do
            fireV2("Weight 10")
            fireV2("Weight 10")
            fireV2("Weight 10")
            task.wait(0.1)
        end
    end)
end)

